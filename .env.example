# =============================================================================
# ConsistenCy 2.0 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# =============================================================================

# =============================================================================
# 必需配置
# =============================================================================

# LiteLLM API Key - 用于 AI 代码审查
# 支持：DeepSeek, OpenAI, Anthropic, Grok 等
# 格式取决于你使用的 provider
LITELLM_API_KEY=your_litellm_api_key_here

# GitHub Token - 用于 PR 评论和仓库访问
# 需要权限: repo, pull_requests:write, issues:write
GITHUB_TOKEN=ghp_your_github_token_here

# =============================================================================
# LLM 配置
# =============================================================================

# 默认模型（LiteLLM 格式）
# 示例：deepseek/deepseek-chat, anthropic/claude-3-sonnet-20240229, openai/gpt-4
LITELLM_MODEL=deepseek/deepseek-chat

# 备选模型（用于重试或降级）
LITELLM_FALLBACK_MODEL=anthropic/claude-3-haiku-20240307

# 模型温度（0-1，越低越确定）
LITELLM_TEMPERATURE=0.3

# 最大 token 数
LITELLM_MAX_TOKENS=4096

# 请求超时（秒）
LITELLM_TIMEOUT=60

# =============================================================================
# GitHub 集成配置
# =============================================================================

# GitHub App / Action 配置
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# PR 评论配置
# 是否删除旧评论再发布新评论
GITHUB_DELETE_OLD_COMMENTS=true

# 评论签名（用于识别 ConsistenCy 的评论）
GITHUB_COMMENT_SIGNATURE=<!-- ConsistenCy 2.0 Code Review -->

# 并发 PR 处理数
GITHUB_MAX_CONCURRENT_PRS=5

# =============================================================================
# GitNexus MCP 配置
# =============================================================================

# MCP 服务器地址（本地或远程）
GITNEXUS_MCP_URL=http://localhost:3000/sse

# 或 MCP 命令路径（如果使用 stdio 模式）
GITNEXUS_MCP_COMMAND=npx
GITNEXUS_MCP_ARGS=-y,@gitnexus/mcp@latest

# 图谱缓存目录
GITNEXUS_CACHE_DIR=.cache/gitnexus

# 图谱 TTL（秒，默认 3600）
GITNEXUS_CACHE_TTL=3600

# =============================================================================
# 扫描器配置
# =============================================================================

# 安全扫描
# Semgrep 规则路径（留空使用默认）
SEMGREP_RULES=p/security-audit p/owasp-top-ten p/cwe-top-25

# Bandit 严重程度阈值（LOW, MEDIUM, HIGH）
BANDIT_SEVERITY=LOW

# 是否启用 Safety（检查依赖漏洞）
ENABLE_SAFETY_CHECK=true

# 一致性漂移检测
# Embedding 模型
DRIFT_EMBEDDING_MODEL=all-MiniLM-L6-v2

# 是否启用 embedding 计算（禁用可显著加快扫描速度）
DRIFT_ENABLE_EMBEDDING=true

# 漂移检测阈值（0-1，越高越严格）
DRIFT_THRESHOLD=0.75

# 统计偏离 Z-score 阈值
DRIFT_ZSCORE_THRESHOLD=2.0

# 技术债务分析
# 复杂度阈值（A-F，A 最简单）
HOTSPOT_COMPLEXITY_THRESHOLD=C

# 变更频率计算天数
HOTSPOT_LOOKBACK_DAYS=90

# =============================================================================
# Dashboard 配置
# =============================================================================

# Streamlit 端口
STREAMLIT_PORT=8501

# 数据持久化目录
DASHBOARD_DATA_DIR=data

# 是否启用实时模式（监控 git 变化）
DASHBOARD_REALTIME=false

# =============================================================================
# 缓存配置
# =============================================================================

# 全局缓存目录
CACHE_DIR=.cache

# 缓存最大大小（MB）
CACHE_MAX_SIZE=1000

# 是否启用内存缓存
ENABLE_MEMORY_CACHE=true

# =============================================================================
# 日志配置
# =============================================================================

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志格式
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# 是否启用结构化日志（JSON）
ENABLE_STRUCTURED_LOG=false

# =============================================================================
# 高级配置
# =============================================================================

# 工作线程数（0=自动）
WORKER_THREADS=0

# 异步并发限制
MAX_CONCURRENT_REQUESTS=10

# 请求重试次数
MAX_RETRIES=3

# 重试延迟（秒）
RETRY_DELAY=1.0

# 是否启用遥测（仅收集使用统计，无敏感数据）
ENABLE_TELEMETRY=false
