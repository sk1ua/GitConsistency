# =============================================================================
# GitConsistency - 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# 所有变量使用 CONSISTENCY_ 前缀
# =============================================================================

# =============================================================================
# 必需配置
# =============================================================================

# LiteLLM API Key - 用于 AI 代码审查
# 支持：DeepSeek, OpenAI, Anthropic, Grok 等
CONSISTENCY_LITELLM_API_KEY=your_litellm_api_key_here

# GitHub Token - 用于 PR 评论和仓库访问
# 需要权限: repo, pull_requests:write
CONSISTENCY_GITHUB_TOKEN=ghp_your_github_token_here

# =============================================================================
# LLM 配置（可选）
# =============================================================================

# 默认模型（LiteLLM 格式）
CONSISTENCY_LITELLM_MODEL=deepseek/deepseek-chat

# 备选模型（用于重试或降级）
CONSISTENCY_LITELLM_FALLBACK_MODEL=anthropic/claude-3-haiku-20240307

# 模型温度（0-1，越低越确定）
CONSISTENCY_LITELLM_TEMPERATURE=0.3

# 最大 token 数
CONSISTENCY_LITELLM_MAX_TOKENS=4096

# 请求超时（秒）
CONSISTENCY_LITELLM_TIMEOUT=60

# =============================================================================
# GitHub 集成配置（可选）
# =============================================================================

# 是否删除旧评论再发布新评论
CONSISTENCY_GITHUB_DELETE_OLD_COMMENTS=true

# 评论签名（用于识别 GitConsistency 的评论）
CONSISTENCY_GITHUB_COMMENT_SIGNATURE=<!-- GitConsistency Code Review -->

# =============================================================================
# GitNexus MCP 配置（可选，实验性功能）
# =============================================================================

# MCP 服务器地址
CONSISTENCY_GITNEXUS_MCP_URL=

# 图谱缓存目录
CONSISTENCY_GITNEXUS_CACHE_DIR=.cache/gitnexus

# 图谱 TTL（秒）
CONSISTENCY_GITNEXUS_CACHE_TTL=3600

# =============================================================================
# 安全扫描器配置（可选）
# =============================================================================

# Semgrep 规则路径
CONSISTENCY_SEMGREP_RULES=p/security-audit p/owasp-top-ten p/cwe-top-25

# Bandit 严重程度阈值（LOW, MEDIUM, HIGH）
CONSISTENCY_BANDIT_SEVERITY=LOW

# =============================================================================
# 缓存配置（可选）
# =============================================================================

# 全局缓存目录
CONSISTENCY_CACHE_DIR=.cache

# 缓存最大大小（MB）
CONSISTENCY_CACHE_MAX_SIZE=1000

# 是否启用内存缓存
CONSISTENCY_ENABLE_MEMORY_CACHE=true

# =============================================================================
# 日志配置（可选）
# =============================================================================

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
CONSISTENCY_LOG_LEVEL=INFO
